class Solution {
public:
    int maxProfit(vector<int>& prices) {

        // stores maximum profit found till now
        int maxProfit = 0;

        // stores minimum buying price till now
        int minBuy = prices[0];

        // traverse the array
        for(int i = 0; i < prices.size(); i++) {

            // if current price is smaller,
            // update best buying price
            if(prices[i] < minBuy) {
                minBuy = prices[i];
            }

            // calculate profit if sold today
            int currentProfit = prices[i] - minBuy;

            // update maximum profit
            if(currentProfit > maxProfit) {
                maxProfit = currentProfit;
            }
        }

        // final answer
        return maxProfit;
    }
};
