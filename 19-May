class Solution {
public:
    bool containsDuplicate(vector<int>& nums) {

        // traverse each element
        for(int i = 0; i < nums.size(); i++) {

            // compare with remaining elements
            for(int j = i + 1; j < nums.size(); j++) {

                // duplicate found
                if(nums[i] == nums[j]) {
                    return true;
                }
            }
        }

        // no duplicate found
        return false;
    }
};

